/* eslint-disable no-console */
import { PrismaClient } from '@prisma/client';
import bcrypt from 'bcryptjs';
import dayjs from 'dayjs';
import { calcEmi, amortisation, round2 } from '../src/lib/finance';

const prisma = new PrismaClient();

/* ── tiny random helpers ──────────────────────────────────────────────── */
const pick = <T>(arr: T[]): T => arr[Math.floor(Math.random() * arr.length)];
const randInt = (min: number, max: number) => Math.floor(Math.random() * (max - min + 1)) + min;
const amt = (min: number, max: number) => round2(randInt(min, max) + Math.random());
const daysAgo = (n: number) => dayjs().subtract(n, 'day').toDate();
const id = () => Math.random().toString(36).slice(2);

const FIRST = ['Aarav', 'Vivaan', 'Diya', 'Ananya', 'Kabir', 'Ishaan', 'Sara', 'Myra', 'Reyansh', 'Aadhya', 'Arjun', 'Saanvi', 'Vihaan', 'Anika', 'Krishna', 'Riya', 'Dev', 'Tara', 'Aryan', 'Meera'];
const LAST = ['Sharma', 'Patel', 'Reddy', 'Iyer', 'Nair', 'Mehta', 'Gupta', 'Singh', 'Verma', 'Rao', 'Kapoor', 'Joshi'];
const COMPANIES = ['Lumina Retail', 'Apex Logistics', 'Verdant Foods', 'Quantum Labs', 'Northwind Traders', 'BlueOrbitMedia', 'Helios Energy', 'Marigold Textiles', 'Cobalt Systems', 'Riverstone Realty'];
const BANKS = ['HDFC Bank', 'ICICI Bank', 'Axis Bank', 'State Bank of India', 'Kotak Mahindra', 'Yes Bank'];

async function clean() {
  // delete in FK-safe order
  await prisma.$transaction([
    prisma.sipInstallment.deleteMany(),
    prisma.investment.deleteMany(),
    prisma.cardTransaction.deleteMany(),
    prisma.card.deleteMany(),
    prisma.sanctionScreening.deleteMany(),
    prisma.sanctionEntry.deleteMany(),
    prisma.treasuryAllocation.deleteMany(),
    prisma.treasuryAccount.deleteMany(),
    prisma.reconciliationItem.deleteMany(),
    prisma.reconciliationBatch.deleteMany(),
    prisma.ledgerEntry.deleteMany(),
    prisma.ledgerJournal.deleteMany(),
    prisma.ledgerAccount.deleteMany(),
    prisma.creditBureauReport.deleteMany(),
    prisma.beneficiary.deleteMany(),
    prisma.customer.deleteMany(),
    prisma.refund.deleteMany(),
    prisma.workflowStep.deleteMany(),
    prisma.workflowInstance.deleteMany(),
    prisma.workflowDefinition.deleteMany(),
    prisma.fraudAlert.deleteMany(),
    prisma.fraudRule.deleteMany(),
    prisma.kycDocument.deleteMany(),
    prisma.kycProfile.deleteMany(),
    prisma.emiSchedule.deleteMany(),
    prisma.loan.deleteMany(),
    prisma.transaction.deleteMany(),
    prisma.transfer.deleteMany(),
    prisma.payment.deleteMany(),
    prisma.expense.deleteMany(),
    prisma.document.deleteMany(),
    prisma.notification.deleteMany(),
    prisma.auditLog.deleteMany(),
    prisma.account.deleteMany(),
    prisma.paymentGateway.deleteMany(),
    prisma.orgSettings.deleteMany(),
    prisma.mfaConfig.deleteMany(),
    prisma.userSession.deleteMany(),
    prisma.userProfile.deleteMany(),
    prisma.passwordResetToken.deleteMany(),
    prisma.user.deleteMany(),
    prisma.tenant.deleteMany(),
  ]);
}

async function main() {
  console.log('🌱  Seeding FinTech database…');
  await clean();
  const hash = await bcrypt.hash('Password123!', 10);

  /* ── Tenants ────────────────────────────────────────────────────────── */
  const primary = await prisma.tenant.create({
    data: { name: 'Northwind Financial', slug: 'northwind', plan: 'scale', isActive: true },
  });
  const otherTenants = await Promise.all(
    [
      { name: 'Lumina Retail', slug: 'lumina', plan: 'growth' },
      { name: 'Apex Logistics', slug: 'apex', plan: 'enterprise' },
      { name: 'Verdant Foods', slug: 'verdant', plan: 'growth' },
      { name: 'Cobalt Systems', slug: 'cobalt', plan: 'free' },
    ].map((t) => prisma.tenant.create({ data: { ...t, isActive: Math.random() > 0.15 } })),
  );

  /* ── Users (primary tenant) ─────────────────────────────────────────── */
  const team: { id: string; name: string; email: string; role: string }[] = [];
  const roster = [
    { firstName: 'Kuldip', lastName: 'Savaliya', email: 'owner@northwind.io', role: 'owner', jobTitle: 'Founder & CEO' },
    // ── Demo login accounts (shown on the Login page) — all use password "Password123!" ──
    { firstName: 'Alex', lastName: 'Carter', email: 'admin@fintech.io', role: 'admin', jobTitle: 'Administrator' },
    { firstName: 'Emma', lastName: 'Stone', email: 'partner@fintech.io', role: 'partner', jobTitle: 'Channel Partner' },
    { firstName: 'Ryan', lastName: 'Lee', email: 'user@fintech.io', role: 'user', jobTitle: 'Team Member' },
    { firstName: 'Priya', lastName: 'Menon', email: 'priya.admin@northwind.io', role: 'admin', jobTitle: 'Head of Operations' },
    { firstName: 'Rahul', lastName: 'Verma', email: 'rahul.finance@northwind.io', role: 'finance_manager', jobTitle: 'Finance Manager' },
    { firstName: 'Sneha', lastName: 'Iyer', email: 'sneha.accounts@northwind.io', role: 'accountant', jobTitle: 'Senior Accountant' },
    { firstName: 'Amit', lastName: 'Rao', email: 'amit.risk@northwind.io', role: 'analyst', jobTitle: 'Risk Analyst' },
  ];
  for (const r of roster) {
    const u = await prisma.user.create({
      data: {
        tenantId: primary.id, email: r.email, password: hash, firstName: r.firstName, lastName: r.lastName,
        phone: `+91 ${randInt(70, 99)}${randInt(10000000, 99999999)}`, role: r.role, isActive: true,
        profile: { create: { jobTitle: r.jobTitle, company: 'Northwind Financial', department: 'Finance', city: 'Bengaluru', state: 'Karnataka' } },
      },
    });
    team.push({ id: u.id, name: `${u.firstName} ${u.lastName}`, email: u.email, role: u.role });
  }
  // extra members for richer user lists
  for (let i = 0; i < 9; i++) {
    const fn = pick(FIRST), ln = pick(LAST);
    const u = await prisma.user.create({
      data: {
        tenantId: primary.id, email: `${fn}.${ln}.${i}@northwind.io`.toLowerCase(), password: hash,
        firstName: fn, lastName: ln, phone: `+91 ${randInt(70, 99)}${randInt(10000000, 99999999)}`,
        role: 'member', isActive: Math.random() > 0.1,
      },
    });
    team.push({ id: u.id, name: `${fn} ${ln}`, email: u.email, role: 'member' });
  }
  // a couple of users in other tenants (for super-admin user list)
  for (const t of otherTenants) {
    for (let i = 0; i < randInt(2, 4); i++) {
      const fn = pick(FIRST), ln = pick(LAST);
      await prisma.user.create({
        data: {
          tenantId: t.id, email: `${fn}.${ln}.${t.slug}${i}@example.com`.toLowerCase(), password: hash,
          firstName: fn, lastName: ln, role: pick(['admin', 'finance_manager', 'member']), isActive: Math.random() > 0.2,
        },
      });
    }
  }
  const owner = team[0];

  /* ── Org settings + gateways ────────────────────────────────────────── */
  await prisma.orgSettings.create({
    data: {
      tenantId: primary.id, name: 'Northwind Financial', registeredAddress: '4th Floor, Prestige Tech Park, Bengaluru 560103',
      cin: 'U65999KA2021PTC148210', gstin: '29ABCDE1234F1Z5', pan: 'ABCDE1234F', baseCurrency: 'INR',
      invoicePrefix: 'NWF-', invoiceStartNumber: 1001, defaultGstRate: 18, primaryColor: '#2667FF',
    },
  });
  await prisma.paymentGateway.createMany({
    data: [
      { tenantId: primary.id, gatewayId: 'razorpay', displayName: 'Razorpay', connected: true, mode: 'live', publicKey: 'rzp_live_8xQ1mK3nP9z', webhookSecret: 'whsec_rzp_29ab84jd', enabledMethods: JSON.stringify(['card', 'upi', 'netbanking', 'wallet']), isPrimary: true, lastSuccessfulPayment: daysAgo(1) },
      { tenantId: primary.id, gatewayId: 'payu', displayName: 'PayU', connected: false, mode: 'test', enabledMethods: JSON.stringify(['card', 'upi']), isPrimary: false },
    ],
  });

  /* ── Accounts ───────────────────────────────────────────────────────── */
  const accountTypes = ['current', 'savings', 'escrow', 'nodal', 'wallet'];
  const accounts: { id: string; name: string; balance: number }[] = [];
  for (let i = 0; i < 12; i++) {
    const type = i < 2 ? 'current' : pick(accountTypes);
    const bank = pick(BANKS);
    const balance = amt(50000, 4000000);
    const a = await prisma.account.create({
      data: {
        tenantId: primary.id, userId: pick(team).id, name: `${type[0].toUpperCase()}${type.slice(1)} — ${bank}`,
        accountType: type, bankName: bank, accountNumber: `${randInt(1000, 9999)}${randInt(100000, 999999)}`,
        ifscCode: `${bank.slice(0, 4).toUpperCase()}0${randInt(100000, 999999)}`, balance, lockedBalance: round2(balance * Math.random() * 0.05),
        currency: 'INR', status: i === 11 ? 'frozen' : 'active', createdAt: daysAgo(randInt(120, 700)),
      },
    });
    accounts.push({ id: a.id, name: a.name!, balance });
  }

  /* ── Transactions (6 months, for cashflow) ──────────────────────────── */
  const txTypes = ['credit', 'debit', 'transfer', 'fee', 'interest', 'refund'];
  const txn: any[] = [];
  for (let i = 0; i < 320; i++) {
    const acc = pick(accounts);
    const type = pick(txTypes);
    const isIn = ['credit', 'interest', 'refund'].includes(type);
    txn.push({
      tenantId: primary.id, accountId: acc.id,
      fromAccountId: isIn ? null : acc.id, toAccountId: isIn ? acc.id : null,
      amount: amt(500, 250000), transactionType: type, status: pick(['completed', 'completed', 'completed', 'pending', 'failed']),
      description: pick(['Vendor payout', 'Customer settlement', 'Payroll batch', 'GST payment', 'Subscription charge', 'Interest credit', 'Service fee', 'Refund processed']),
      referenceNo: `TXN-${id().toUpperCase().slice(0, 8)}`, idempotencyKey: `seed-${i}-${id()}`,
      createdAt: daysAgo(randInt(0, 180)),
    });
  }
  await prisma.transaction.createMany({ data: txn });

  /* ── Transfers ──────────────────────────────────────────────────────── */
  const transfers: any[] = [];
  for (let i = 0; i < 45; i++) {
    const from = pick(accounts), to = pick(accounts.filter((a) => a.id !== from.id));
    transfers.push({
      tenantId: primary.id, fromAccount: from.name, toAccount: to.name, amount: amt(1000, 500000),
      description: pick(['Inter-account sweep', 'Treasury rebalance', 'Vendor settlement', 'Reserve top-up']),
      status: pick(['completed', 'completed', 'pending']), reference: `TRF-${id().toUpperCase().slice(0, 8)}`, date: daysAgo(randInt(0, 120)),
    });
  }
  await prisma.transfer.createMany({ data: transfers });

  /* ── Payments + refunds ─────────────────────────────────────────────── */
  const payments = [];
  for (let i = 0; i < 130; i++) {
    const p = await prisma.payment.create({
      data: {
        tenantId: primary.id, gateway: pick(['razorpay', 'razorpay', 'payu']), gatewayOrderId: `order_${id().slice(0, 14)}`,
        amount: amt(199, 180000), currency: 'INR', status: pick(['captured', 'captured', 'captured', 'authorized', 'created', 'failed']),
        payer: `${pick(FIRST)} ${pick(LAST)}`, description: pick(['Order payment', 'Invoice settlement', 'Subscription renewal', 'Top-up']),
        createdAt: daysAgo(randInt(0, 150)),
      },
    });
    payments.push(p);
  }
  const captured = payments.filter((p) => p.status === 'captured');
  for (let i = 0; i < 28; i++) {
    const p = pick(captured);
    const full = Math.random() > 0.5;
    const refundAmount = full ? p.amount : round2(p.amount * (0.2 + Math.random() * 0.5));
    await prisma.refund.create({
      data: {
        tenantId: primary.id, paymentId: p.id, paymentReference: p.gatewayOrderId, originalAmount: p.amount,
        refundAmount, type: full ? 'full' : 'partial', reason: pick(['customer_request', 'duplicate_payment', 'product_return', 'fraud', 'other']),
        notes: pick(['Customer cancelled order', 'Duplicate charge reversed', 'Goods returned', '']),
        status: pick(['completed', 'completed', 'processing', 'failed']), customer: p.payer, gatewayRefundId: `rfnd_${id().slice(0, 12)}`,
        requestedBy: owner.id, createdAt: daysAgo(randInt(0, 90)),
      },
    });
  }

  /* ── Expenses ───────────────────────────────────────────────────────── */
  const categories = ['travel', 'meals', 'software', 'office', 'marketing', 'utilities', 'other'];
  const expenses: any[] = [];
  for (let i = 0; i < 90; i++) {
    const member = pick(team);
    const status = pick(['pending', 'approved', 'approved', 'rejected', 'reimbursed']);
    expenses.push({
      tenantId: primary.id, userId: member.id, employeeName: member.name, category: pick(categories), amount: amt(200, 85000),
      description: pick(['Client visit cab', 'Team lunch', 'SaaS subscription', 'Stationery', 'Ad campaign', 'Electricity bill', 'Conference ticket']),
      status, approvedBy: status === 'pending' ? null : owner.id, approvedAt: status === 'pending' ? null : daysAgo(randInt(0, 30)),
      createdAt: daysAgo(randInt(0, 120)),
    });
  }
  await prisma.expense.createMany({ data: expenses });

  /* ── Loans + EMI schedules ──────────────────────────────────────────── */
  const loanSpecs: Array<{ status: string; paidFraction: number }> = [
    { status: 'applied', paidFraction: 0 },
    { status: 'applied', paidFraction: 0 },
    { status: 'applied', paidFraction: 0 },
    { status: 'applied', paidFraction: 0 },
    { status: 'applied', paidFraction: 0 },
    { status: 'npa',     paidFraction: 0.15 },
    { status: 'npa',     paidFraction: 0.25 },
    { status: 'npa',     paidFraction: 0.10 },
    { status: 'closed',  paidFraction: 1 },
    { status: 'closed',  paidFraction: 1 },
    { status: 'closed',  paidFraction: 1 },
    { status: 'active',  paidFraction: 0.30 },
    { status: 'active',  paidFraction: 0.50 },
    { status: 'active',  paidFraction: 0.20 },
    { status: 'active',  paidFraction: 0.60 },
    { status: 'active',  paidFraction: 0.45 },
    { status: 'active',  paidFraction: 0.10 },
    { status: 'active',  paidFraction: 0.70 },
    { status: 'active',  paidFraction: 0.35 },
    { status: 'active',  paidFraction: 0.55 },
    { status: 'active',  paidFraction: 0.25 },
    { status: 'active',  paidFraction: 0.80 },
    { status: 'active',  paidFraction: 0.15 },
    { status: 'active',  paidFraction: 0.40 },
    { status: 'active',  paidFraction: 0.65 },
  ];
  for (const spec of loanSpecs) {
    const principal  = amt(100000, 5000000);
    const rate       = randInt(9, 18);
    const tenure     = pick([12, 24, 36, 48, 60]);
    const emi        = calcEmi(principal, rate, tenure);
    const loanType   = pick(['personal', 'business', 'working_capital', 'auto', 'mortgage']);
    if (spec.status === 'applied') {
      await prisma.loan.create({
        data: {
          tenantId: primary.id, accountId: pick(accounts).id, borrower: `${pick(FIRST)} ${pick(LAST)}`,
          loanType, principal, interestRate: rate, tenureMonths: tenure, emiAmount: emi,
          status: 'applied', createdAt: daysAgo(randInt(1, 30)),
        },
      });
    } else {
      const disbursedAt = daysAgo(randInt(60, 500));
      const paidCount   = spec.status === 'closed'
        ? tenure
        : Math.max(1, Math.floor(tenure * spec.paidFraction));
      const schedule    = amortisation(principal, rate, tenure);
      await prisma.loan.create({
        data: {
          tenantId: primary.id, accountId: pick(accounts).id, borrower: `${pick(FIRST)} ${pick(LAST)}`,
          loanType, principal, interestRate: rate, tenureMonths: tenure, emiAmount: emi,
          status: spec.status, disbursedAt, createdAt: disbursedAt,
          emiSchedule: {
            create: schedule.map((row, idx) => ({
              installment: row.installment,
              dueDate: dayjs(disbursedAt).add(row.installment, 'month').toDate(),
              principal: row.principal, interest: row.interest, emiAmount: row.emiAmount,
              status:  idx < paidCount ? 'paid'
                     : (spec.status === 'npa' && idx === paidCount) ? 'overdue'
                     : 'pending',
              paidAt: idx < paidCount ? dayjs(disbursedAt).add(row.installment, 'month').toDate() : null,
            })),
          },
        },
      });
    }
  }

  /* ── Credit profiles ────────────────────────────────────────────────── */
  for (const member of team.slice(0, 10)) {
    const score = randInt(540, 880);
    const totalDebt = amt(0, 1500000);
    const available = amt(100000, 3000000);
    await prisma.creditProfile.create({
      data: {
        tenantId: primary.id, userId: member.id, userName: member.name, userEmail: member.email, creditScore: score, scoreModel: 'CIBIL',
        totalDebt, availableCredit: available, utilizationPct: round2((totalDebt / (totalDebt + available)) * 100),
        onTimePayments: randInt(10, 90), latePayments: randInt(0, 8), defaults: Math.random() > 0.85 ? 1 : 0,
        riskCategory: score >= 750 ? 'low' : score >= 650 ? 'medium' : score >= 550 ? 'high' : 'very_high', lastUpdated: daysAgo(randInt(0, 40)),
      },
    });
  }

  /* ── KYC profiles + documents ───────────────────────────────────────── */
  for (let i = 0; i < 22; i++) {
    const member = pick(team);
    const status = pick(['pending', 'verified', 'verified', 'rejected', 'review']);
    const kyc = await prisma.kycProfile.create({
      data: {
        tenantId: primary.id, userId: member.id, userName: member.name,
        panNumber: `${pick(['ABCDE', 'PQRSX', 'LMNOP'])}${randInt(1000, 9999)}${pick(['A', 'B', 'C'])}`,
        aadhaarNumber: `XXXX-XXXX-${randInt(1000, 9999)}`, panVerified: status === 'verified', aadhaarVerified: status === 'verified',
        faceMatchScore: round2(70 + Math.random() * 30), riskLevel: pick(['low', 'low', 'medium', 'high']), status,
        rejectionReason: status === 'rejected' ? pick(['PAN name mismatch', 'Blurred document', 'Expired ID']) : null,
        reviewedBy: status === 'pending' ? null : owner.id, reviewedAt: status === 'pending' ? null : daysAgo(randInt(0, 30)), createdAt: daysAgo(randInt(0, 120)),
        documents: {
          create: [
            { docType: 'pan', fileUrl: 'https://files.local/pan.pdf', fileName: 'pan_card.pdf', fileSize: randInt(80000, 400000), mimeType: 'application/pdf', isVerified: status === 'verified' },
            { docType: 'aadhaar', fileUrl: 'https://files.local/aadhaar.pdf', fileName: 'aadhaar.pdf', fileSize: randInt(80000, 400000), mimeType: 'application/pdf', isVerified: status === 'verified' },
          ],
        },
      },
    });
    void kyc;
  }

  /* ── Fraud rules + alerts ───────────────────────────────────────────── */
  const rules = await Promise.all([
    prisma.fraudRule.create({ data: { tenantId: primary.id, name: 'High-velocity transactions', ruleType: 'velocity', action: 'flag', severity: 'high', description: 'More than 10 transactions in 5 minutes', triggerCount: randInt(2, 40) } }),
    prisma.fraudRule.create({ data: { tenantId: primary.id, name: 'Large amount threshold', ruleType: 'amount_threshold', action: 'review', severity: 'medium', description: 'Single transaction above ₹5,00,000', triggerCount: randInt(2, 40) } }),
    prisma.fraudRule.create({ data: { tenantId: primary.id, name: 'Geo anomaly', ruleType: 'geo_anomaly', action: 'block', severity: 'critical', description: 'Login from new country', triggerCount: randInt(0, 12) } }),
    prisma.fraudRule.create({ data: { tenantId: primary.id, name: 'Blacklisted beneficiary', ruleType: 'blacklist', action: 'block', severity: 'critical', description: 'Payout to flagged account', triggerCount: randInt(0, 8) } }),
    prisma.fraudRule.create({ data: { tenantId: primary.id, name: 'New device', ruleType: 'device', action: 'notify', severity: 'low', description: 'Transaction from unrecognised device', triggerCount: randInt(5, 60) } }),
  ]);
  const alerts: any[] = [];
  for (let i = 0; i < 34; i++) {
    const rule = pick(rules);
    alerts.push({
      tenantId: primary.id, userId: pick(team).id, ruleId: rule.id, alertType: rule.ruleType, severity: rule.severity,
      description: `${rule.name} triggered for a ${pick(['payout', 'card payment', 'UPI transfer', 'wallet load'])}`,
      riskScore: round2(30 + Math.random() * 70), status: pick(['open', 'open', 'investigating', 'resolved', 'dismissed']),
      createdAt: daysAgo(randInt(0, 60)),
    });
  }
  await prisma.fraudAlert.createMany({ data: alerts });

  /* ── Audit logs ─────────────────────────────────────────────────────── */
  const actions = ['create', 'update', 'delete', 'login', 'approve', 'reject', 'export'];
  const resources = ['account', 'payment', 'loan', 'ledger', 'expense', 'kyc', 'user', 'settings'];
  const logs: any[] = [];
  for (let i = 0; i < 160; i++) {
    const member = pick(team);
    logs.push({
      tenantId: primary.id, userId: member.id, action: pick(actions), resource: pick(resources), resourceId: id().slice(0, 10),
      ipAddress: `${randInt(10, 220)}.${randInt(0, 255)}.${randInt(0, 255)}.${randInt(1, 254)}`,
      userAgent: pick(['Chrome/124 · macOS', 'Safari/17 · iOS', 'Edge/124 · Windows', 'Firefox/126 · Linux']),
      status: pick(['success', 'success', 'success', 'failure']), duration: randInt(12, 900), createdAt: daysAgo(randInt(0, 90)),
    });
  }
  await prisma.auditLog.createMany({ data: logs });

  /* ── Workflows ──────────────────────────────────────────────────────── */
  const defs = await Promise.all([
    prisma.workflowDefinition.create({ data: { tenantId: primary.id, name: 'Expense Approval', type: 'expense_approval' } }),
    prisma.workflowDefinition.create({ data: { tenantId: primary.id, name: 'Loan Approval', type: 'loan_approval' } }),
    prisma.workflowDefinition.create({ data: { tenantId: primary.id, name: 'Refund Approval', type: 'refund_approval' } }),
    prisma.workflowDefinition.create({ data: { tenantId: primary.id, name: 'KYC Review', type: 'kyc_review' } }),
  ]);
  for (let i = 0; i < 26; i++) {
    const def = pick(defs);
    const totalSteps = randInt(2, 3);
    const status = pick(['pending', 'in_progress', 'approved', 'approved', 'rejected']);
    const current = status === 'approved' ? totalSteps : status === 'rejected' ? randInt(0, totalSteps - 1) : randInt(0, totalSteps - 1);
    await prisma.workflowInstance.create({
      data: {
        tenantId: primary.id, definitionId: def.id, referenceId: id().slice(0, 10), referenceType: def.type.split('_')[0],
        currentStep: current, totalSteps, status, priority: pick(['low', 'medium', 'high', 'urgent']),
        assignedTo: pick(team).name, dueAt: daysAgo(randInt(-14, 7)), completedAt: ['approved', 'rejected'].includes(status) ? daysAgo(randInt(0, 20)) : null,
        createdAt: daysAgo(randInt(0, 45)),
        steps: {
          create: Array.from({ length: totalSteps }, (_, s) => ({
            stepIndex: s, stepName: pick(['Manager review', 'Finance sign-off', 'Compliance check', 'Director approval']),
            assignedTo: pick(team).name,
            status: s < current ? 'approved' : s === current && status === 'rejected' ? 'rejected' : 'pending',
            comment: s < current ? pick(['Looks good', 'Approved within policy', 'Verified documents']) : null,
            actionedAt: s < current ? daysAgo(randInt(0, 20)) : null, actionedBy: s < current ? pick(team).name : null,
          })),
        },
      },
    });
  }

  /* ── Documents ──────────────────────────────────────────────────────── */
  const docs: any[] = [];
  for (let i = 0; i < 30; i++) {
    const member = pick(team);
    docs.push({
      tenantId: primary.id, userId: member.id, name: pick(['Q3 Financial Report', 'Vendor Agreement', 'Bank Statement', 'GST Return', 'Audit Report', 'Loan Sanction Letter']),
      docCategory: pick(['contract', 'statement', 'report', 'kyc', 'tax', 'other']), fileUrl: 'https://files.local/document.pdf',
      fileName: `doc_${id().slice(0, 8)}.pdf`, fileSize: randInt(50000, 5000000), mimeType: 'application/pdf',
      isEncrypted: Math.random() > 0.5, accessLevel: pick(['private', 'team', 'tenant']), uploadedBy: member.name, createdAt: daysAgo(randInt(0, 150)),
    });
  }
  await prisma.document.createMany({ data: docs });

  /* ── Notifications ──────────────────────────────────────────────────── */
  const notifs: any[] = [];
  for (let i = 0; i < 40; i++) {
    notifs.push({
      tenantId: primary.id, userId: owner.id, channel: pick(['in_app', 'email', 'sms', 'push']), type: pick(['info', 'success', 'warning', 'alert', 'transaction']),
      title: pick(['Payment received', 'Expense approved', 'Fraud alert', 'Reconciliation complete', 'KYC verified', 'Loan EMI due']),
      body: pick(['A new payment of ₹12,500 was captured.', 'Your expense claim was approved.', 'A high-risk transaction was flagged.', 'Bank statement reconciled with 2 exceptions.', 'KYC verification completed.', 'EMI of ₹18,400 is due in 3 days.']),
      status: pick(['sent', 'delivered', 'read', 'read']), sentAt: daysAgo(randInt(0, 30)), createdAt: daysAgo(randInt(0, 30)),
    });
  }
  await prisma.notification.createMany({ data: notifs });

  // a few sessions for the owner (Security page)
  await prisma.userSession.createMany({
    data: [
      { userId: owner.id, ipAddress: '103.21.58.12', userAgent: 'Chrome/124 · macOS', expiresAt: dayjs().add(7, 'day').toDate(), createdAt: daysAgo(0) },
      { userId: owner.id, ipAddress: '49.36.220.7', userAgent: 'Safari/17 · iPhone', expiresAt: dayjs().add(5, 'day').toDate(), createdAt: daysAgo(2) },
      { userId: owner.id, ipAddress: '157.48.91.30', userAgent: 'Edge/124 · Windows', expiresAt: dayjs().add(3, 'day').toDate(), createdAt: daysAgo(6) },
    ],
  });

  // historical sessions for the demo login accounts so their Security page shows
  // multiple active devices (in addition to the session created at each login)
  for (const email of ['admin@fintech.io', 'partner@fintech.io', 'user@fintech.io']) {
    const u = team.find((t) => t.email === email);
    if (!u) continue;
    await prisma.userSession.createMany({
      data: [
        { userId: u.id, ipAddress: '103.21.58.12', userAgent: 'Chrome/124 · Windows', expiresAt: dayjs().add(6, 'day').toDate(), createdAt: daysAgo(1) },
        { userId: u.id, ipAddress: '49.36.220.7', userAgent: 'Safari/17 · iPhone', expiresAt: dayjs().add(4, 'day').toDate(), createdAt: daysAgo(3) },
      ],
    });
  }

  /* ── Customers (M2) ─────────────────────────────────────────────────── */
  const customerData = [
    { fn: 'Rohan',    ln: 'Sharma',   email: 'rohan.sharma@northwind.io',    emp: 'salaried',      employer: 'Infosys Limited',              income: 1200000 },
    { fn: 'Aisha',    ln: 'Khan',     email: 'aisha.khan@northwind.io',      emp: 'salaried',      employer: 'HDFC Bank',                    income: 850000  },
    { fn: 'Vikram',   ln: 'Nair',     email: 'vikram.nair@northwind.io',     emp: 'self_employed', employer: 'VN Consultants',               income: 2000000 },
    { fn: 'Divya',    ln: 'Patel',    email: 'divya.patel@northwind.io',     emp: 'business',      employer: 'Patel Textiles Pvt Ltd',       income: 3500000 },
    { fn: 'Suresh',   ln: 'Reddy',    email: 'suresh.reddy@northwind.io',    emp: 'salaried',      employer: 'Wipro Technologies',           income: 950000  },
