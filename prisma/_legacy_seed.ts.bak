    { fn: 'Karan',    ln: 'Mehta',    email: 'karan.mehta@northwind.io',     emp: 'business',      employer: 'Mehta Exports Pvt Ltd',        income: 4200000 },
    { fn: 'Pooja',    ln: 'Gupta',    email: 'pooja.gupta@northwind.io',     emp: 'salaried',      employer: 'Accenture India',              income: 1100000 },
    { fn: 'Nikhil',   ln: 'Rao',      email: 'nikhil.rao@northwind.io',      emp: 'self_employed', employer: 'NR Tech Solutions',            income: 1800000 },
    { fn: 'Priya',    ln: 'Kapoor',   email: 'priya.kapoor@northwind.io',    emp: 'salaried',      employer: 'Deloitte India',               income: 2200000 },
    { fn: 'Sanjay',   ln: 'Verma',    email: 'sanjay.verma@northwind.io',    emp: 'business',      employer: 'Verma Industries Ltd',         income: 5000000 },
    { fn: 'Anita',    ln: 'Desai',    email: 'anita.desai@northwind.io',     emp: 'salaried',      employer: 'HCL Technologies',             income: 980000  },
    { fn: 'Rahul',    ln: 'Bose',     email: 'rahul.bose@northwind.io',      emp: 'salaried',      employer: 'Amazon India',                 income: 1900000 },
    { fn: 'Sneha',    ln: 'Pillai',   email: 'sneha.pillai@northwind.io',    emp: 'salaried',      employer: 'Flipkart',                     income: 1400000 },
    { fn: 'Amit',     ln: 'Saxena',   email: 'amit.saxena@northwind.io',     emp: 'self_employed', employer: 'Saxena & Associates',          income: 2600000 },
    { fn: 'Lakshmi',  ln: 'Krishnan', email: 'lakshmi.krishnan@northwind.io',emp: 'retired',       employer: 'Former Bank Manager',          income: 560000  },
    { fn: 'Rohit',    ln: 'Tiwari',   email: 'rohit.tiwari@northwind.io',    emp: 'salaried',      employer: 'Reliance Industries',          income: 1750000 },
    { fn: 'Sunita',   ln: 'Agarwal',  email: 'sunita.agarwal@northwind.io',  emp: 'business',      employer: 'Agarwal Jewellers',            income: 3200000 },
    { fn: 'Deepak',   ln: 'Chandra',  email: 'deepak.chandra@northwind.io',  emp: 'salaried',      employer: 'Cognizant Technology',         income: 1050000 },
    { fn: 'Rekha',    ln: 'Pandey',   email: 'rekha.pandey@northwind.io',    emp: 'salaried',      employer: 'State Bank of India',          income: 780000  },
    { fn: 'Manish',   ln: 'Kumar',    email: 'manish.kumar@northwind.io',    emp: 'business',      employer: 'Kumar Constructions Pvt Ltd',  income: 6000000 },
    { fn: 'Geeta',    ln: 'Malhotra', email: 'geeta.malhotra@northwind.io',  emp: 'self_employed', employer: 'Malhotra Designs',             income: 1350000 },
    { fn: 'Varun',    ln: 'Bhatt',    email: 'varun.bhatt@northwind.io',     emp: 'salaried',      employer: 'Google India',                 income: 3800000 },
  ];
  const cities  = ['Bengaluru', 'Mumbai', 'Hyderabad', 'Delhi', 'Pune', 'Chennai'];
  const states  = ['Karnataka', 'Maharashtra', 'Telangana', 'Delhi', 'Tamil Nadu'];
  const areas   = ['Indiranagar', 'Koramangala', 'HSR Layout', 'Whitefield', 'Bandra West', 'Andheri East'];
  const panPfx  = ['AAPCS', 'BQPME', 'CRTXL', 'DRXYZ', 'ESTAB'];
  const customers: { id: string; firstName: string; lastName: string }[] = [];
  for (let i = 0; i < customerData.length; i++) {
    const c = customerData[i];
    const kycStatus = pick(['verified', 'verified', 'pending', 'rejected']);
    const cust = await prisma.customer.create({
      data: {
        tenantId: primary.id,
        customerId: `CIF${String(1001 + i).padStart(6, '0')}`,
        firstName: c.fn, lastName: c.ln, email: c.email,
        phone: `+91 ${randInt(70, 99)}${randInt(10000000, 99999999)}`,
        dob: `${randInt(1965, 1998)}-${String(randInt(1, 12)).padStart(2, '0')}-${String(randInt(1, 28)).padStart(2, '0')}`,
        gender: pick(['male', 'female']),
        panNumber: `${pick(panPfx)}${randInt(1000, 9999)}${pick(['A', 'B', 'F'])}`,
        aadhaarLast4: String(randInt(1000, 9999)),
        employmentType: c.emp, employerName: c.employer, annualIncome: c.income,
        address1: `${randInt(10, 500)}, ${pick(areas)} Main Road`,
        city: pick(cities), state: pick(states), pincode: String(randInt(100001, 799999)),
        status: pick(['active', 'active', 'active', 'inactive']),
        kycStatus, riskCategory: pick(['low', 'low', 'medium', 'high']),
        nomineeName: `${pick(FIRST)} ${pick(LAST)}`, nomineeRelation: pick(['spouse', 'parent', 'sibling', 'child']),
        createdAt: daysAgo(randInt(10, 400)),
      },
    });
    customers.push({ id: cust.id, firstName: cust.firstName, lastName: cust.lastName });
  }

  /* ── Beneficiaries (M7) ──────────────────────────────────────────────── */
  const beneficiaryBanks = ['HDFC Bank', 'ICICI Bank', 'Axis Bank', 'SBI', 'Kotak Mahindra'];
  const ifscPfx = ['HDFC', 'ICIC', 'UTIB', 'SBIN', 'KKBK'];
  for (const cust of customers) {
    const bCount = randInt(1, 3);
    for (let b = 0; b < bCount; b++) {
      const bankIdx = randInt(0, beneficiaryBanks.length - 1);
      const status  = pick(['active', 'active', 'pending', 'blocked']);
      await prisma.beneficiary.create({
        data: {
          tenantId: primary.id, customerId: cust.id,
          name: `${pick(FIRST)} ${pick(LAST)}`, nickName: pick(['Family', 'Business', 'Vendor', undefined]),
          bankName: beneficiaryBanks[bankIdx],
          accountNumber: `${randInt(10000000, 99999999)}${randInt(100, 999)}`,
          ifscCode: `${ifscPfx[bankIdx]}0${randInt(100000, 999999)}`,
          accountType: pick(['savings', 'current', 'wallet']),
          upiId: Math.random() > 0.5 ? `${cust.firstName.toLowerCase()}@upi` : undefined,
          phone: `+91 ${randInt(70, 99)}${randInt(10000000, 99999999)}`,
          relationship: pick(['family', 'business', 'other', 'self']),
          status, approvedBy: status === 'active' ? owner.id : undefined,
          approvedAt: status === 'active' ? daysAgo(randInt(1, 60)) : undefined,
          createdAt: daysAgo(randInt(1, 200)),
        },
      });
    }
  }

  /* ── Chart of Accounts (M18 Ledger) ─────────────────────────────────── */
  const coa = [
    // Assets
    { code: '1001', name: 'Cash & Bank',         accountType: 'asset',     category: 'cash',      balance: 5820000,  isSystem: true,  description: 'Main cash and liquid bank balances' },
    { code: '1002', name: 'Current Bank Account', accountType: 'asset',     category: 'bank',      balance: 12400000, isSystem: true,  description: 'Primary operating current account' },
    { code: '1003', name: 'Savings Reserve',      accountType: 'asset',     category: 'bank',      balance: 8600000,  isSystem: false, description: 'SBI savings reserve account' },
    { code: '1010', name: 'Accounts Receivable',  accountType: 'asset',     category: 'receivable',balance: 3240000,  isSystem: true,  description: 'Outstanding customer invoices and dues' },
    { code: '1020', name: 'Loan Portfolio',        accountType: 'asset',     category: 'loan',      balance: 22800000, isSystem: true,  description: 'Total outstanding loan principal' },
    { code: '1030', name: 'Prepaid Expenses',      accountType: 'asset',     category: 'receivable',balance: 480000,   isSystem: false, description: 'Prepaid insurance, rent, and subscriptions' },
    // Liabilities
    { code: '2001', name: 'Accounts Payable',     accountType: 'liability', category: 'payable',   balance: 1820000,  isSystem: true,  description: 'Amounts owed to vendors and suppliers' },
    { code: '2002', name: 'Customer Deposits',    accountType: 'liability', category: 'payable',   balance: 9400000,  isSystem: true,  description: 'Savings deposits and wallet balances held' },
    { code: '2003', name: 'Borrowings — NABARD',  accountType: 'liability', category: 'loan',      balance: 15000000, isSystem: false, description: 'Refinance borrowing from NABARD' },
    { code: '2010', name: 'Tax Payable',           accountType: 'liability', category: 'payable',   balance: 640000,   isSystem: false, description: 'GST and income tax outstanding' },
    // Equity
    { code: '3001', name: 'Share Capital',         accountType: 'equity',   category: 'equity_ctrl',balance: 10000000, isSystem: true,  description: 'Paid-up equity share capital' },
    { code: '3002', name: 'Retained Earnings',     accountType: 'equity',   category: 'equity_ctrl',balance: 16280000, isSystem: true,  description: 'Accumulated retained profits' },
    // Revenue
    { code: '4001', name: 'Interest Income',       accountType: 'revenue',  category: 'income',    balance: 4820000,  isSystem: true,  description: 'Interest earned on loans and investments' },
    { code: '4002', name: 'Transaction Fee Income',accountType: 'revenue',  category: 'income',    balance: 1240000,  isSystem: true,  description: 'Processing fees on payments and transfers' },
    { code: '4003', name: 'Commission Income',     accountType: 'revenue',  category: 'income',    balance: 680000,   isSystem: false, description: 'Referral and distribution commissions' },
    { code: '4004', name: 'Penalty Income',        accountType: 'revenue',  category: 'income',    balance: 320000,   isSystem: false, description: 'Late payment and foreclosure penalties' },
    // Expenses
    { code: '5001', name: 'Employee Expenses',     accountType: 'expense',  category: 'expense_ctrl',balance: 2400000, isSystem: true,  description: 'Salaries, bonuses, and benefits' },
    { code: '5002', name: 'Technology & IT',        accountType: 'expense',  category: 'expense_ctrl',balance: 680000,  isSystem: true,  description: 'Cloud, SaaS, hardware, and software' },
    { code: '5003', name: 'Marketing & Acquisition',accountType: 'expense', category: 'expense_ctrl',balance: 420000,  isSystem: false, description: 'Digital ads, campaigns, and events' },
    { code: '5004', name: 'Loan Loss Provision',   accountType: 'expense',  category: 'expense_ctrl',balance: 960000,  isSystem: true,  description: 'Provision for non-performing loans' },
    { code: '5005', name: 'Operations Overhead',   accountType: 'expense',  category: 'expense_ctrl',balance: 380000,  isSystem: false, description: 'Rent, utilities, office, and admin' },
  ];
  const ledgerAccounts: any[] = [];
  for (const a of coa) {
    const acc = await prisma.ledgerAccount.create({ data: { ...a, tenantId: primary.id } });
    ledgerAccounts.push(acc);
  }
  const getAcc = (code: string) => ledgerAccounts.find((a: any) => a.code === code)!;

  /* ── Journal Entries (M18) ───────────────────────────────────────────── */
  const journalTemplates = [
    { desc: 'Loan disbursement — Personal Loan', refType: 'loan',    dr: '1010', cr: '1002', amount: 500000 },
    { desc: 'EMI collection — Auto Loan',         refType: 'loan',    dr: '1002', cr: '4001', amount: 18500  },
    { desc: 'Payment gateway settlement',          refType: 'payment', dr: '1001', cr: '1002', amount: 238400 },
    { desc: 'Vendor payout — IT services',         refType: 'payment', dr: '2001', cr: '1002', amount: 85000  },
    { desc: 'Salary batch — June 2025',            refType: 'expense', dr: '5001', cr: '1002', amount: 420000 },
    { desc: 'Interest income accrual',             refType: 'manual',  dr: '1010', cr: '4001', amount: 32000  },
    { desc: 'Loan loss provision — Q2',            refType: 'manual',  dr: '5004', cr: '2001', amount: 120000 },
    { desc: 'Fee income — transaction charges',    refType: 'payment', dr: '1002', cr: '4002', amount: 14200  },
    { desc: 'Customer deposit receipt',            refType: 'payment', dr: '1002', cr: '2002', amount: 250000 },
    { desc: 'Marketing campaign spend',            refType: 'expense', dr: '5003', cr: '1002', amount: 75000  },
    { desc: 'Penalty collection — late EMI',       refType: 'loan',    dr: '1002', cr: '4004', amount: 4500   },
    { desc: 'NABARD refinance drawdown',           refType: 'manual',  dr: '1002', cr: '2003', amount: 2000000},
    { desc: 'Cloud infra invoice — AWS',           refType: 'expense', dr: '5002', cr: '2001', amount: 48000  },
    { desc: 'Commission payout — DSA',             refType: 'payment', dr: '4003', cr: '1002', amount: 22000  },
    { desc: 'GST liability settlement',            refType: 'expense', dr: '2010', cr: '1002', amount: 95000  },
    { desc: 'Prepaid insurance payment',           refType: 'expense', dr: '1030', cr: '1002', amount: 36000  },
    { desc: 'Interest on borrowings — NABARD',     refType: 'manual',  dr: '5004', cr: '1002', amount: 62500  },
    { desc: 'Refund of duplicate payment',         refType: 'payment', dr: '2002', cr: '1002', amount: 8400   },
    { desc: 'Office rent — Bengaluru HQ',          refType: 'expense', dr: '5005', cr: '2001', amount: 120000 },
    { desc: 'Annual compliance filing fee',        refType: 'manual',  dr: '5005', cr: '1002', amount: 15000  },
  ];
  for (let j = 0; j < journalTemplates.length; j++) {
    const t   = journalTemplates[j];
    const drA = getAcc(t.dr);
    const crA = getAcc(t.cr);
    const jNo = `JNL-${String(1001 + j).padStart(6, '0')}`;
    const postedAt = daysAgo(randInt(0, 120));
    await prisma.ledgerJournal.create({
      data: {
        tenantId: primary.id, journalNo: jNo, description: t.desc,
        referenceType: t.refType, referenceId: `REF-${id().slice(0, 8).toUpperCase()}`,
        status: 'posted', totalDebit: t.amount, totalCredit: t.amount,
        createdBy: owner.id, postedAt,
        entries: {
          create: [
            { tenantId: primary.id, accountId: drA.id, entryType: 'debit',  amount: t.amount, description: t.desc, createdAt: postedAt },
            { tenantId: primary.id, accountId: crA.id, entryType: 'credit', amount: t.amount, description: t.desc, createdAt: postedAt },
          ],
        },
      },
    });
  }

  /* ── Reconciliation Batches (M19) ────────────────────────────────────── */
  const recBatch1Items: any[] = [];
  const recBatch2Items: any[] = [];
  for (let i = 0; i < 20; i++) {
    const isDebit = i % 2 === 0;
    const amount  = amt(5000, 250000);
    recBatch1Items.push({ itemType: isDebit ? 'debit' : 'credit', amount, description: pick(['NEFT inward', 'RTGS outward', 'UPI credit', 'Cheque clearance', 'Standing instruction']), status: i < 14 ? 'matched' : i < 18 ? 'unmatched' : 'exception', matchedAt: i < 14 ? daysAgo(randInt(1, 5)) : null, exception: i >= 18 ? 'Large transaction requires manual review' : null });
    recBatch2Items.push({ itemType: isDebit ? 'debit' : 'credit', amount: amt(1000, 80000), description: pick(['Gateway settlement', 'Chargeback', 'Fee reversal', 'Payout']), status: 'unmatched' });
  }
  const b1 = await prisma.reconciliationBatch.create({
    data: {
      tenantId: primary.id, batchNo: 'REC-001001', batchType: 'bank',
      period: '2025-05', status: 'completed',
      totalItems: 20, matched: 14, unmatched: 4, exceptions: 2,
      startedAt: daysAgo(10), completedAt: daysAgo(9),
    },
  });
  await prisma.reconciliationItem.createMany({ data: recBatch1Items.map(i => ({ ...i, batchId: b1.id, tenantId: primary.id, createdAt: daysAgo(randInt(9, 15)) })) });
  const b2 = await prisma.reconciliationBatch.create({
    data: {
      tenantId: primary.id, batchNo: 'REC-001002', batchType: 'payment_gateway',
      period: '2025-06', status: 'pending',
      totalItems: 20, matched: 0, unmatched: 20, exceptions: 0,
    },
  });
  await prisma.reconciliationItem.createMany({ data: recBatch2Items.map(i => ({ ...i, batchId: b2.id, tenantId: primary.id, createdAt: daysAgo(randInt(0, 3)) })) });

  /* ── Treasury Accounts (M20) ─────────────────────────────────────────── */
  const treAccounts: { id: string; name: string }[] = [];
  const treData = [
    { name: 'Primary Operating Account', accountType: 'operating',  balance: 12400000, minBalance: 2000000, bankName: 'HDFC Bank',  accountNumber: '50200012345678' },
    { name: 'Reserve Fund',              accountType: 'reserve',    balance: 8600000,  minBalance: 5000000, bankName: 'SBI',        accountNumber: '30291048301248' },
    { name: 'Liquidity Pool',            accountType: 'liquidity',  balance: 6200000,  minBalance: 1000000, bankName: 'Axis Bank',  accountNumber: '91502934850234' },
    { name: 'Investment Account',        accountType: 'investment', balance: 15000000, minBalance: 0,       bankName: 'ICICI Bank', accountNumber: '00791028374651' },
  ];
  for (const t of treData) {
    const ta = await prisma.treasuryAccount.create({ data: { ...t, tenantId: primary.id, currency: 'INR', status: 'active' } });
    treAccounts.push({ id: ta.id, name: ta.name });
  }
  const allocPurposes = ['liquidity', 'investment', 'reserve', 'payment', 'transfer'];
  for (let i = 0; i < 12; i++) {
    const from = treAccounts[Math.floor(i / 3) % treAccounts.length];
    const to   = treAccounts[(Math.floor(i / 3) + 1) % treAccounts.length];
    await prisma.treasuryAllocation.create({
      data: {
        tenantId: primary.id, fromAccountId: from.id, toAccountId: to.id, toAccountName: to.name,
        amount: amt(100000, 2000000), purpose: pick(allocPurposes), status: pick(['completed', 'completed', 'pending']),
        notes: pick(['Monthly reserve rebalancing', 'Liquidity buffer top-up', 'Investment window placement', 'End-of-day sweep', undefined]),
        allocationDate: daysAgo(randInt(0, 90)), createdAt: daysAgo(randInt(0, 90)),
      },
    });
  }

  /* ── Cards (M21) ─────────────────────────────────────────────────────── */
  const cardCards: { id: string }[] = [];
  const networks  = ['visa', 'mastercard', 'rupay'];
  const merchants = ['Amazon India', 'Swiggy', 'Zomato', 'Uber', 'Flipkart', 'BookMyShow', 'Myntra', 'BigBasket', 'MakeMyTrip', 'Netflix India', 'Reliance Digital'];
  const cardSpecs = [
    { cardType: 'virtual',  cardVariant: 'debit',   cardholderName: 'Rohan Sharma',   isInternational: false },
    { cardType: 'physical', cardVariant: 'debit',   cardholderName: 'Aisha Khan',     isInternational: false },
    { cardType: 'virtual',  cardVariant: 'credit',  cardholderName: 'Vikram Nair',    isInternational: true  },
    { cardType: 'physical', cardVariant: 'debit',   cardholderName: 'Divya Patel',    isInternational: false },
    { cardType: 'virtual',  cardVariant: 'debit',   cardholderName: 'Suresh Reddy',   isInternational: false },
    { cardType: 'physical', cardVariant: 'credit',  cardholderName: 'Arjun Singh',    isInternational: true  },
    { cardType: 'virtual',  cardVariant: 'prepaid', cardholderName: 'Meera Iyer',     isInternational: false },
    { cardType: 'physical', cardVariant: 'debit',   cardholderName: 'Kavita Joshi',   isInternational: false },
    { cardType: 'virtual',  cardVariant: 'debit',   cardholderName: 'Alex Carter',    isInternational: true  },
    { cardType: 'physical', cardVariant: 'credit',  cardholderName: 'Emma Stone',     isInternational: true  },
  ];
  const expYear = new Date().getFullYear() + 3;
  for (let i = 0; i < cardSpecs.length; i++) {
    const spec   = cardSpecs[i];
    const last4  = String(1000 + randInt(0, 8999));
    const status = i === 3 ? 'blocked' : pick(['active', 'active', 'active', 'frozen']);
    const card   = await prisma.card.create({
      data: {
        tenantId: primary.id, userId: pick(team).id,
        ...spec, maskedNumber: `**** **** **** ${last4}`,
        expiryMonth: randInt(1, 12), expiryYear: expYear + randInt(0, 2),
        network: pick(networks), status,
        dailyLimit:   spec.cardVariant === 'credit' ? 500000 : 100000,
        monthlyLimit: spec.cardVariant === 'credit' ? 2000000 : 500000,
        isContactless: true, isOnlineEnabled: true,
        blockedAt:    status === 'blocked' ? daysAgo(randInt(1, 30)) : null,
        blockedReason: status === 'blocked' ? 'Suspicious activity reported by cardholder' : null,
        createdAt: daysAgo(randInt(30, 365)),
      },
    });
    cardCards.push({ id: card.id });
    const txCount = randInt(8, 18);
    const cardTxns: any[] = [];
    for (let t = 0; t < txCount; t++) {
      const txStatus = pick(['approved', 'approved', 'approved', 'declined', 'reversed']);
      cardTxns.push({
        cardId: card.id, tenantId: primary.id,
        merchant: pick(merchants), amount: amt(99, 25000), currency: 'INR',
        status: txStatus, txnType: pick(['purchase', 'purchase', 'purchase', 'withdrawal', 'refund']),
        mcc: pick(['5411', '5812', '4121', '5999', '7922', '5691']),
        location: pick(['Bengaluru', 'Mumbai', 'Delhi', 'Online', 'Hyderabad']),
        createdAt: daysAgo(randInt(0, 60)),
      });
    }
    await prisma.cardTransaction.createMany({ data: cardTxns });
  }

  /* ── Credit Bureau Reports (M12) ─────────────────────────────────────── */
  const bureaus = ['experian', 'equifax', 'crif', 'transunion'];
  for (const cust of customers.slice(0, 6)) {
    const bureauCount = randInt(1, 3);
    for (let b = 0; b < bureauCount; b++) {
      const baseScore = randInt(550, 880);
      await prisma.creditBureauReport.create({
        data: {
          tenantId: primary.id, customerId: cust.id, bureau: bureaus[b % bureaus.length],
          reportReference: `${bureaus[b % bureaus.length].toUpperCase()}-${Date.now() + b}`,
          creditScore: baseScore,
          paymentHistory:    round2(70 + Math.random() * 30),
          creditUtilization: round2(Math.random() * 60),
          accountAgeMonths:  randInt(12, 120),
          recentInquiries:   randInt(0, 5),
          derogatoryMarks:   Math.random() > 0.8 ? 1 : 0,
          totalAccounts:     randInt(2, 10),
          openAccounts:      randInt(1, 5),
          totalBalance:      amt(10000, 500000),
          totalLimit:        amt(100000, 2000000),
          status: 'active',
          pulledAt: daysAgo(randInt(0, 80)),
          expiresAt: dayjs().add(90, 'day').toDate(),
        },
      });
    }
  }

  /* ── AML / Sanction Entries (M15) ────────────────────────────────────── */
  const sanctionData = [
    { entityName: 'Khan Trading Associates',    entityType: 'entity',     listType: 'ofac',         country: 'AE', reason: 'Suspected money laundering network' },
    { entityName: 'Blackwater Holdings Ltd',    entityType: 'entity',     listType: 'un',           country: 'US', reason: 'Arms trafficking and sanctions evasion' },
    { entityName: 'Viktor Petrov',              entityType: 'individual', listType: 'eu',            country: 'RU', reason: 'Linked to sanctioned oligarch network' },
    { entityName: 'Global Shell Corp Intl',     entityType: 'entity',     listType: 'ofac',         country: 'BZ', reason: 'Shell company used for illicit transfers' },
    { entityName: 'Rajesh Malhotra',            entityType: 'individual', listType: 'pep',           country: 'IN', reason: 'Politically exposed person — former minister' },
    { entityName: 'Sunrise Investments LLC',    entityType: 'entity',     listType: 'adverse_media',country: 'MU', reason: 'Adverse media — fraud investigation ongoing' },
    { entityName: 'Deepak Arora Foundation',    entityType: 'entity',     listType: 'pep',           country: 'IN', reason: 'Front organization for PEP funds' },
    { entityName: 'Caribbean Offshore Bank',    entityType: 'entity',     listType: 'un',           country: 'KY', reason: 'Correspondent banking violation' },
    { entityName: 'Ahmad Al-Rashid',            entityType: 'individual', listType: 'ofac',         country: 'SA', reason: 'Suspected terrorist financing' },
    { entityName: 'Eurasia Trade Consortium',   entityType: 'entity',     listType: 'eu',            country: 'BY', reason: 'Dual-use goods export violations' },
  ];
  const sanctionEntries: { id: string; entityName: string }[] = [];
  for (const s of sanctionData) {
    const entry = await prisma.sanctionEntry.create({ data: { ...s, tenantId: primary.id, isActive: true, addedAt: daysAgo(randInt(10, 500)) } });
    sanctionEntries.push({ id: entry.id, entityName: entry.entityName });
  }

  /* ── AML Screenings ──────────────────────────────────────────────────── */
  const screeningSubjects = [
    { entityName: 'Apex Global Payments',    score: 12,  status: 'clear',  refType: 'payment'    },
    { entityName: 'Khan Trading Associates', score: 95,  status: 'match',  refType: 'payment'    },
    { entityName: 'Rajesh Malhotra',         score: 88,  status: 'match',  refType: 'customer'   },
    { entityName: 'Lumina Exporters Pvt Ltd',score: 18,  status: 'clear',  refType: 'beneficiary'},
    { entityName: 'Viktor Petrov Trading',   score: 72,  status: 'review', refType: 'payment'    },
    { entityName: 'Global Shell Corp Intl',  score: 96,  status: 'match',  refType: 'payment'    },
    { entityName: 'Sunrise Tech Solutions',  score: 22,  status: 'clear',  refType: 'beneficiary'},
    { entityName: 'Deepak Arora',            score: 68,  status: 'review', refType: 'customer'   },
    { entityName: 'Priya Sharma Exports',    score: 10,  status: 'clear',  refType: 'payment'    },
    { entityName: 'Caribbean Offshore Bank', score: 92,  status: 'match',  refType: 'payment'    },
    { entityName: 'Verdant Foods Trading',   score: 8,   status: 'clear',  refType: 'beneficiary'},
    { entityName: 'Ahmad Al-Rashid Holdings',score: 90,  status: 'match',  refType: 'payment'    },
  ];
  for (const sc of screeningSubjects) {
    const matchedEntry = sanctionEntries.find(e => sc.entityName.toLowerCase().includes(e.entityName.toLowerCase().split(' ')[0].toLowerCase()));
    await prisma.sanctionScreening.create({
      data: {
        tenantId: primary.id, sanctionId: matchedEntry?.id ?? null,
        entityName: sc.entityName, entityType: sc.refType,
        referenceId: `REF-${id().slice(0, 8).toUpperCase()}`, referenceType: sc.refType,
        matchScore: sc.score, status: sc.status,
        resolvedBy: ['clear', 'match'].includes(sc.status) && Math.random() > 0.5 ? owner.id : undefined,
        resolvedAt: ['clear', 'match'].includes(sc.status) && Math.random() > 0.5 ? daysAgo(randInt(0, 10)) : undefined,
        notes: sc.status === 'match' ? 'High confidence match. Escalated to compliance officer.' : sc.status === 'review' ? 'Partial match. Manual review required.' : null,
        createdAt: daysAgo(randInt(0, 60)),
      },
    });
  }

  /* ── Investments (M22) ──────────────────────────────────────────────── */
  const fundNames = [
    { name: 'Axis Bluechip Fund – Direct Growth',         type: 'mutual_fund', nav: 48.23, units: 412.5  },
    { name: 'Mirae Asset Large Cap Fund – Direct Growth', type: 'mutual_fund', nav: 82.67, units: 183.2  },
    { name: 'HDFC Mid-Cap Opportunities Fund',            type: 'mutual_fund', nav: 121.4, units: 97.8   },
    { name: 'SBI Nifty 50 Index Fund',                    type: 'mutual_fund', nav: 205.3, units: 58.6   },
    { name: 'ICICI Prudential Technology Fund',           type: 'mutual_fund', nav: 148.9, units: 134.0  },
    { name: 'HDFC Fixed Deposit – 2Y',  type: 'fixed_deposit', interestRate: 7.25, duration: 24 },
    { name: 'Axis Bank FD – 1Y',        type: 'fixed_deposit', interestRate: 7.0,  duration: 12 },
    { name: 'ICICI Bank FD – 3Y',       type: 'fixed_deposit', interestRate: 7.5,  duration: 36 },
    { name: 'Axis Bluechip Fund SIP',   type: 'sip', sipAmount: 5000,  duration: 24 },
    { name: 'Mirae Emerging Bluechip SIP', type: 'sip', sipAmount: 3000, duration: 12 },
  ];

  for (let fi = 0; fi < fundNames.length; fi++) {
    const f = fundNames[fi];
    const cust = customers[fi % customers.length];
    const startDate = daysAgo(randInt(30, 365));

    let investedAmount: number;
    let currentValue:   number;
    let units = 0, nav = 0;

    if (f.type === 'mutual_fund') {
      units = (f as any).units;
      nav   = (f as any).nav;
      const initNav = nav * (1 - randInt(5, 20) / 100);
      investedAmount = round2(units * initNav);
      currentValue   = round2(units * nav);
    } else if (f.type === 'fixed_deposit') {
      investedAmount = amt(100000, 1000000);
      const months   = (f as any).duration as number;
      const rate     = ((f as any).interestRate as number) / 100;
      currentValue   = round2(investedAmount * (1 + rate * months / 12));
    } else {
      // SIP
      const sipAmt   = (f as any).sipAmount as number;
      const paid     = randInt(2, (f as any).duration as number);
      investedAmount = round2(sipAmt * paid);
      currentValue   = round2(investedAmount * (1 + randInt(5, 15) / 100));
    }

    const returnAmount = round2(currentValue - investedAmount);
    const returnRate   = round2(investedAmount > 0 ? (returnAmount / investedAmount) * 100 : 0);

    const maturityDate = f.type !== 'mutual_fund'
      ? dayjs(startDate).add((f as any).duration as number, 'month').toDate()
      : undefined;

    const inv = await prisma.investment.create({
      data: {
        tenantId: primary.id,
        customerId: cust.id,
        investmentType: f.type as any,
        fundName: f.name,
        folio: f.type === 'mutual_fund' ? `FOLIO${String(fi + 10001).padStart(6, '0')}` : undefined,
        investedAmount, currentValue, returnAmount, returnRate,
        units, nav,
        interestRate:  (f as any).interestRate ?? null,
        duration:      (f as any).duration ?? null,
        sipAmount:     (f as any).sipAmount ?? null,
        sipFrequency:  f.type === 'sip' ? 'monthly' : null,
        status:        Math.random() > 0.15 ? 'active' : 'matured',
        startDate,
        maturityDate: maturityDate ?? null,
        createdAt:    startDate,
      },
    });

    // SIP installments
    if (f.type === 'sip') {
      const total = (f as any).duration as number;
      const paid  = randInt(2, total);
      for (let i = 0; i < total; i++) {
        const d = dayjs(startDate).add(i, 'month').toDate();
        await prisma.sipInstallment.create({
          data: {
            investmentId: inv.id,
            installmentNo: i + 1,
            amount: (f as any).sipAmount,
            dueDate: d,
            status:  i < paid ? 'paid' : 'pending',
            paidAt:  i < paid ? d : null,
            units:   i < paid ? round2(((f as any).sipAmount / nav) * (1 + Math.random() * 0.1)) : null,
            nav:     i < paid ? round2(nav * (0.85 + Math.random() * 0.2)) : null,
          },
        });
      }
    }
  }

  const counts = {
    tenants: 1 + otherTenants.length, users: await prisma.user.count(), accounts: accounts.length,
    transactions: txn.length, payments: payments.length, loans: loanSpecs.length,
    customers: customers.length, ledgerAccounts: coa.length, cards: cardCards.length,
    sanctionEntries: sanctionData.length,
    investments: fundNames.length,
  };
  console.log('✅  Seed complete:', counts);
  console.log('🔑  Login: owner@northwind.io / Password123!');
}

main()
  .catch((e) => { console.error(e); process.exit(1); })
  .finally(async () => { await prisma.$disconnect(); });
