// FinPay — Accounting & Finance SaaS
// PostgreSQL schema. Multi-tenant (tenantId on every business table), UUID PKs,
// soft-delete where configurable, immutable ledger + audit, reporting indexes.
//
// Conventions:
//  - tenantId is a scalar @db.Uuid (NOT a Prisma relation) → tenant isolation is
//    enforced by application middleware; kept scalar to avoid a 35-way Tenant fan-out
//    and to keep cross-tenant queries impossible-by-construction in the repository layer.
//  - Intra-tenant referential integrity IS modeled as real relations.
//  - Money is stored as Decimal(18,4) — never Float. Currency is ISO-4217 code.
//  - Ledger (JournalLine) and AuditLog rows are append-only; the service layer never updates them.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Identity, tenancy & security
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  slug         String    @unique
  legalName    String?
  email        String?
  phone        String?
  taxId        String?
  baseCurrency String    @default("INR")
  country      String    @default("IN")
  timezone     String    @default("Asia/Kolkata")
  logoUrl      String?
  status       String    @default("active") // active | suspended
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  users       User[]
  memberships Membership[]

  @@index([status])
  @@map("tenants")
}

// A user is a global identity; Membership binds a user to a tenant with roles.
model User {
  id               String    @id @default(uuid()) @db.Uuid
  email            String    @unique
  passwordHash     String
  firstName        String
  lastName         String
  avatarUrl        String?
  status           String    @default("active") // active | locked | invited | disabled
  emailVerifiedAt  DateTime?
  lastLoginAt      DateTime?
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  mfaEnabled       Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  // Home tenant for convenience; full access is via Membership.
  tenantId String? @db.Uuid
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  memberships    Membership[]
  sessions       UserSession[]
  refreshTokens  RefreshToken[]
  mfaConfig      MfaConfig?
  passwordResets PasswordResetToken[]
  emailTokens    EmailVerificationToken[]
  loginAttempts  LoginAttempt[]

  @@index([status])
  @@map("users")
}

// User ↔ Tenant with role assignment (multi-org per user).
model Membership {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  userId    String   @db.Uuid
  status    String   @default("active") // active | invited | disabled
  invitedBy String?  @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  roles  UserRole[]

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("memberships")
}

model UserSession {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  tenantId   String?   @db.Uuid
  ip         String?
  userAgent  String?
  device     String?
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

// Refresh-token rotation: one active token per chain; rotating issues a child and
// revokes the parent. Reuse of a revoked token → whole chain revoked (theft detection).
model RefreshToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  tenantId     String?   @db.Uuid
  tokenHash    String    @unique // SHA-256 of the opaque token; raw never stored
  familyId     String    @db.Uuid // rotation chain id
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?   @unique @db.Uuid
  ip           String?
  userAgent    String?
  createdAt    DateTime  @default(now())

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBy RefreshToken? @relation("TokenRotation", fields: [replacedById], references: [id])
  replaces   RefreshToken? @relation("TokenRotation")

  @@index([userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

model MfaConfig {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @db.Uuid
  secret      String
  verified    Boolean  @default(false)
  backupCodes String[] // hashed backup codes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mfa_configs")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

// Append-only record of authentication attempts for lockout + audit.
model LoginAttempt {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  email     String
  success   Boolean
  ip        String?
  userAgent String?
  reason    String? // bad_password | locked | mfa_failed | ok
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([createdAt])
  @@map("login_attempts")
}

// ─────────────────────────────────────────────────────────────────────────────
// RBAC + PBAC
// ─────────────────────────────────────────────────────────────────────────────

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String?  @db.Uuid // null = system/global role template
  name        String
  key         String // owner | admin | accountant | approver | viewer | ...
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  userRoles   UserRole[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid()) @db.Uuid
  key         String  @unique // e.g. "invoice:create", "ledger:post", "report:read"
  resource    String // invoice | ledger | report | ...
  action      String // create | read | update | delete | post | approve | export
  description String?

  roles RolePermission[]

  @@index([resource])
  @@map("permissions")
}

model RolePermission {
  roleId       String @db.Uuid
  permissionId String @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  membershipId String @db.Uuid
  roleId       String @db.Uuid

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([membershipId, roleId])
  @@map("user_roles")
}

// ─────────────────────────────────────────────────────────────────────────────
// Organization structure & configuration
// ─────────────────────────────────────────────────────────────────────────────

model Department {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @db.Uuid
  name      String
  code      String?
  managerId String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  expenses Expense[]

  @@index([tenantId])
  @@map("departments")
}

model Branch {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @db.Uuid
  name      String
  code      String?
  address   String?
  city      String?
  country   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
  @@map("branches")
}

model FinancialYear {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String // "FY2026-27"
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  status    String   @default("open") // open | closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("financial_years")
}

model Currency {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  code      String // ISO 4217
  name      String
  symbol    String
  rate      Decimal  @default(1) @db.Decimal(18, 6) // vs base currency
  isBase    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("currencies")
}

model TenantSettings {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @unique @db.Uuid
  invoicePrefix     String   @default("INV-")
  invoiceNextNumber Int      @default(1)
  billPrefix        String   @default("BILL-")
  billNextNumber    Int      @default(1)
  journalPrefix     String   @default("JV-")
  journalNextNumber Int      @default(1)
  paymentPrefix     String   @default("PAY-")
  paymentNextNumber Int      @default(1)
  passwordPolicy    Json? // { minLength, requireUpper, requireNumber, requireSymbol, maxAgeDays }
  lockoutThreshold  Int      @default(5)
  lockoutMinutes    Int      @default(15)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("tenant_settings")
}

// ─────────────────────────────────────────────────────────────────────────────
// Tax configuration
// ─────────────────────────────────────────────────────────────────────────────

model TaxRate {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @db.Uuid
  name      String // "GST 18%"
  rate      Decimal   @db.Decimal(9, 4) // percent
  kind      String    @default("output") // output | input
  region    String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  groupRates TaxGroupRate[]

  @@index([tenantId])
  @@map("tax_rates")
}

model TaxGroup {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rates TaxGroupRate[]

  @@index([tenantId])
  @@map("tax_groups")
}

model TaxGroupRate {
  groupId String @db.Uuid
  rateId  String @db.Uuid

  group TaxGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  rate  TaxRate  @relation(fields: [rateId], references: [id], onDelete: Cascade)

  @@id([groupId, rateId])
  @@map("tax_group_rates")
}

// ─────────────────────────────────────────────────────────────────────────────
// Chart of Accounts (hierarchical)
// ─────────────────────────────────────────────────────────────────────────────

model Account {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid
  code           String // account number
  name           String
  type           String // asset | liability | equity | income | expense
  subtype        String? // current_asset | fixed_asset | accounts_receivable | ...
  parentId       String?   @db.Uuid
  isActive       Boolean   @default(true)
  isSystem       Boolean   @default(false) // system accounts (AR, AP, Tax Payable...) not deletable
  openingBalance Decimal   @default(0) @db.Decimal(18, 4)
  currency       String    @default("INR")
  description    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  parent       Account?      @relation("AccountTree", fields: [parentId], references: [id])
  children     Account[]     @relation("AccountTree")
  journalLines JournalLine[]
  bankAccount  BankAccount?
  budgetLines  BudgetLine[]

  @@unique([tenantId, code])
  @@index([tenantId, type])
  @@index([parentId])
  @@map("accounts")
}

// ─────────────────────────────────────────────────────────────────────────────
// General Ledger — double-entry. JournalEntry = header, JournalLine = immutable posting.
// ─────────────────────────────────────────────────────────────────────────────

model JournalEntry {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @db.Uuid
  number       String // JV-000123
  date         DateTime  @db.Date
  memo         String?
  status       String    @default("draft") // draft | pending | posted | reversed
  source       String    @default("manual") // manual | invoice | bill | payment | expense | reversal | opening
  sourceId     String?   @db.Uuid // originating document id
  isRecurring  Boolean   @default(false)
  recurrenceId String?   @db.Uuid
  reversalOfId String?   @unique @db.Uuid
  postedAt     DateTime?
  postedBy     String?   @db.Uuid
  createdBy    String?   @db.Uuid
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  lines      JournalLine[]
  reversalOf JournalEntry?    @relation("JournalReversal", fields: [reversalOfId], references: [id])
  reversedBy JournalEntry?    @relation("JournalReversal")
  approval   ApprovalRequest?

  @@unique([tenantId, number])
  @@index([tenantId, date])
  @@index([tenantId, status])
  @@index([source, sourceId])
  @@map("journal_entries")
}

// Immutable once the parent entry is posted. Sum(debit) must equal Sum(credit) per entry.
model JournalLine {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  entryId     String   @db.Uuid
  accountId   String   @db.Uuid
  debit       Decimal  @default(0) @db.Decimal(18, 4)
  credit      Decimal  @default(0) @db.Decimal(18, 4)
  description String?
  createdAt   DateTime @default(now())

  entry   JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id])

  @@index([tenantId, accountId])
  @@index([entryId])
  @@map("journal_lines")
}

// ─────────────────────────────────────────────────────────────────────────────
// Customers (AR) & Vendors (AP)
// ─────────────────────────────────────────────────────────────────────────────

model Customer {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @db.Uuid
  name            String
  displayName     String?
  email           String?
  phone           String?
  taxId           String?
  billingAddress  String?
  shippingAddress String?
  currency        String    @default("INR")
  creditLimit     Decimal   @default(0) @db.Decimal(18, 4)
  paymentTerms    Int       @default(30) // net days
  notes           String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  invoices        Invoice[]
  payments        Payment[]
  depositAccounts DepositAccount[]

  @@index([tenantId])
  @@index([tenantId, name])
  @@map("customers")
}

model Vendor {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @db.Uuid
  name         String
  displayName  String?
  email        String?
  phone        String?
  taxId        String?
  address      String?
  currency     String    @default("INR")
  paymentTerms Int       @default(30)
  notes        String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  bills    Bill[]
  payments Payment[]
  expenses Expense[]

  @@index([tenantId])
  @@index([tenantId, name])
  @@map("vendors")
}

// ─────────────────────────────────────────────────────────────────────────────
// Invoicing (AR)
// ─────────────────────────────────────────────────────────────────────────────

model Invoice {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid
  number         String // INV-000123
  customerId     String    @db.Uuid
  status         String    @default("draft") // draft | sent | partial | paid | overdue | cancelled
  issueDate      DateTime  @db.Date
  dueDate        DateTime  @db.Date
  currency       String    @default("INR")
  subtotal       Decimal   @default(0) @db.Decimal(18, 4)
  discountTotal  Decimal   @default(0) @db.Decimal(18, 4)
  taxTotal       Decimal   @default(0) @db.Decimal(18, 4)
  total          Decimal   @default(0) @db.Decimal(18, 4)
  amountPaid     Decimal   @default(0) @db.Decimal(18, 4)
  balanceDue     Decimal   @default(0) @db.Decimal(18, 4)
  notes          String?
  terms          String?
  isRecurring    Boolean   @default(false)
  recurrenceId   String?   @db.Uuid
  journalEntryId String?   @db.Uuid
  sentAt         DateTime?
  createdBy      String?   @db.Uuid
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  customer    Customer            @relation(fields: [customerId], references: [id])
  items       InvoiceItem[]
  allocations PaymentAllocation[]
  approval    ApprovalRequest?

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([tenantId, dueDate])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @db.Uuid
  invoiceId   String  @db.Uuid
  description String
  quantity    Decimal @default(1) @db.Decimal(18, 4)
  unitPrice   Decimal @default(0) @db.Decimal(18, 4)
  discount    Decimal @default(0) @db.Decimal(18, 4)
  taxRateId   String? @db.Uuid
  taxAmount   Decimal @default(0) @db.Decimal(18, 4)
  lineTotal   Decimal @default(0) @db.Decimal(18, 4)
  accountId   String? @db.Uuid // income account
  sortOrder   Int     @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// Bills / Purchase invoices (AP)
// ─────────────────────────────────────────────────────────────────────────────

model Bill {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid
  number         String // BILL-000123
  vendorId       String    @db.Uuid
  status         String    @default("draft") // draft | pending | approved | partial | paid | overdue | cancelled
  issueDate      DateTime  @db.Date
  dueDate        DateTime  @db.Date
  currency       String    @default("INR")
  subtotal       Decimal   @default(0) @db.Decimal(18, 4)
  taxTotal       Decimal   @default(0) @db.Decimal(18, 4)
  total          Decimal   @default(0) @db.Decimal(18, 4)
  amountPaid     Decimal   @default(0) @db.Decimal(18, 4)
  balanceDue     Decimal   @default(0) @db.Decimal(18, 4)
  notes          String?
  journalEntryId String?   @db.Uuid
  createdBy      String?   @db.Uuid
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  vendor      Vendor              @relation(fields: [vendorId], references: [id])
  items       BillItem[]
  allocations PaymentAllocation[]
  approval    ApprovalRequest?

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([tenantId, vendorId])
  @@index([tenantId, dueDate])
  @@map("bills")
}

model BillItem {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @db.Uuid
  billId      String  @db.Uuid
  description String
  quantity    Decimal @default(1) @db.Decimal(18, 4)
  unitPrice   Decimal @default(0) @db.Decimal(18, 4)
  taxRateId   String? @db.Uuid
  taxAmount   Decimal @default(0) @db.Decimal(18, 4)
  lineTotal   Decimal @default(0) @db.Decimal(18, 4)
  accountId   String? @db.Uuid // expense account
  sortOrder   Int     @default(0)

  bill Bill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
  @@map("bill_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// Expenses
// ─────────────────────────────────────────────────────────────────────────────

model ExpenseCategory {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  accountId String?  @db.Uuid // expense account mapping
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses Expense[]

  @@index([tenantId])
  @@map("expense_categories")
}

model Expense {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid
  reference      String
  categoryId     String?   @db.Uuid
  vendorId       String?   @db.Uuid
  departmentId   String?   @db.Uuid
  date           DateTime  @db.Date
  amount         Decimal   @db.Decimal(18, 4)
  taxAmount      Decimal   @default(0) @db.Decimal(18, 4)
  currency       String    @default("INR")
  description    String?
  status         String    @default("draft") // draft | pending | approved | rejected | reimbursed
  paymentMethod  String? // cash | bank | card
  isReimbursable Boolean   @default(false)
  isRecurring    Boolean   @default(false)
  receiptUrl     String?
  journalEntryId String?   @db.Uuid
  createdBy      String?   @db.Uuid
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  category   ExpenseCategory? @relation(fields: [categoryId], references: [id])
  vendor     Vendor?          @relation(fields: [vendorId], references: [id])
  department Department?      @relation(fields: [departmentId], references: [id])
  approval   ApprovalRequest?

  @@index([tenantId, status])
  @@index([tenantId, date])
  @@map("expenses")
}

// ─────────────────────────────────────────────────────────────────────────────
// Banking & reconciliation
// ─────────────────────────────────────────────────────────────────────────────

model BankAccount {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid
  accountId      String    @unique @db.Uuid // maps to a COA account (asset)
  name           String
  bankName       String?
  accountNumber  String?
  type           String    @default("bank") // bank | cash
  currency       String    @default("INR")
  currentBalance Decimal   @default(0) @db.Decimal(18, 4)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  account         Account           @relation(fields: [accountId], references: [id])
  transactions    BankTransaction[]
  reconciliations Reconciliation[]

  @@index([tenantId])
  @@map("bank_accounts")
}

model BankTransaction {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  bankAccountId String   @db.Uuid
  date          DateTime @db.Date
  description   String
  reference     String?
  amount        Decimal  @db.Decimal(18, 4) // signed: + credit / - debit
  type          String // credit | debit
  status        String   @default("unmatched") // unmatched | matched | ignored
  matchedType   String? // payment | expense | journal
  matchedId     String?  @db.Uuid
  importBatchId String?  @db.Uuid
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@index([tenantId, bankAccountId])
  @@index([tenantId, status])
  @@index([tenantId, date])
  @@map("bank_transactions")
}

model Reconciliation {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @db.Uuid
  bankAccountId    String    @db.Uuid
  statementDate    DateTime  @db.Date
  statementBalance Decimal   @db.Decimal(18, 4)
  bookBalance      Decimal   @db.Decimal(18, 4)
  difference       Decimal   @default(0) @db.Decimal(18, 4)
  status           String    @default("in_progress") // in_progress | completed
  completedAt      DateTime?
  createdBy        String?   @db.Uuid
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@index([tenantId, bankAccountId])
  @@map("reconciliations")
}

// ─────────────────────────────────────────────────────────────────────────────
// Payments (idempotent) — customer receipts & vendor payments, allocated to docs
// ─────────────────────────────────────────────────────────────────────────────

model Payment {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  number         String // PAY-000123
  direction      String // inbound (customer) | outbound (vendor)
  customerId     String?  @db.Uuid
  vendorId       String?  @db.Uuid
  bankAccountId  String?  @db.Uuid
  date           DateTime @db.Date
  amount         Decimal  @db.Decimal(18, 4)
  currency       String   @default("INR")
  method         String   @default("bank") // bank | cash | card | upi | cheque
  reference      String?
  status         String   @default("completed") // pending | completed | failed
  notes          String?
  journalEntryId String?  @db.Uuid
  createdBy      String?  @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customer    Customer?           @relation(fields: [customerId], references: [id])
  vendor      Vendor?             @relation(fields: [vendorId], references: [id])
  allocations PaymentAllocation[]

  @@unique([tenantId, number])
  @@index([tenantId, direction])
  @@index([tenantId, date])
  @@map("payments")
}

model PaymentAllocation {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @db.Uuid
  paymentId String  @db.Uuid
  invoiceId String? @db.Uuid
  billId    String? @db.Uuid
  amount    Decimal @db.Decimal(18, 4)

  payment Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id])
  bill    Bill?    @relation(fields: [billId], references: [id])

  @@index([paymentId])
  @@index([invoiceId])
  @@index([billId])
  @@map("payment_allocations")
}

// ─────────────────────────────────────────────────────────────────────────────
// Budgeting
// ─────────────────────────────────────────────────────────────────────────────

model Budget {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  name          String
  financialYear String
  period        String   @default("monthly") // monthly | quarterly | yearly
  status        String   @default("draft") // draft | active | archived
  createdBy     String?  @db.Uuid
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lines BudgetLine[]

  @@index([tenantId])
  @@map("budgets")
}

model BudgetLine {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @db.Uuid
  budgetId  String  @db.Uuid
  accountId String  @db.Uuid
  period    String // "2026-04" etc
  amount    Decimal @default(0) @db.Decimal(18, 4)

  budget  Budget  @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id])

  @@index([budgetId])
  @@index([tenantId, accountId])
  @@map("budget_lines")
}

// ─────────────────────────────────────────────────────────────────────────────
// Approval workflow (multi-level)
// ─────────────────────────────────────────────────────────────────────────────

model ApprovalRequest {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  entityType   String // invoice | bill | expense | journal | payment
  status       String   @default("pending") // pending | approved | rejected
  currentLevel Int      @default(1)
  totalLevels  Int      @default(1)
  requestedBy  String?  @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  invoiceId String? @unique @db.Uuid
  billId    String? @unique @db.Uuid
  expenseId String? @unique @db.Uuid
  journalId String? @unique @db.Uuid

  invoice Invoice?       @relation(fields: [invoiceId], references: [id])
  bill    Bill?          @relation(fields: [billId], references: [id])
  expense Expense?       @relation(fields: [expenseId], references: [id])
  journal JournalEntry?  @relation(fields: [journalId], references: [id])
  steps   ApprovalStep[]

  @@index([tenantId, status])
  @@map("approval_requests")
}

model ApprovalStep {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @db.Uuid
  requestId  String    @db.Uuid
  level      Int
  approverId String?   @db.Uuid
  status     String    @default("pending") // pending | approved | rejected
  comment    String?
  actedAt    DateTime?
  createdAt  DateTime  @default(now())

  request ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("approval_steps")
}

// ─────────────────────────────────────────────────────────────────────────────
// Documents, notifications, audit
// ─────────────────────────────────────────────────────────────────────────────

model Document {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @db.Uuid
  name       String
  mimeType   String
  size       Int
  storageKey String // path/key in storage provider
  entityType String? // customer | vendor | invoice | expense | ...
  entityId   String?   @db.Uuid
  uploadedBy String?   @db.Uuid
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?

  @@index([tenantId])
  @@index([entityType, entityId])
  @@map("documents")
}

model Notification {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @db.Uuid
  userId     String?   @db.Uuid // null = tenant-wide
  type       String // invoice_overdue | payment_received | approval_pending | ...
  title      String
  body       String?
  entityType String?
  entityId   String?   @db.Uuid
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId, userId])
  @@index([tenantId, readAt])
  @@map("notifications")
}

// Append-only audit trail with before/after snapshots.
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String?  @db.Uuid
  userId     String?  @db.Uuid
  action     String // create | update | delete | post | approve | login | ...
  module     String // invoice | ledger | auth | ...
  entityType String?
  entityId   String?  @db.Uuid
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([tenantId, module])
  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// Infrastructure: idempotency + transactional outbox
// ─────────────────────────────────────────────────────────────────────────────

model IdempotencyKey {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @db.Uuid
  key          String
  method       String
  path         String
  requestHash  String
  statusCode   Int?
  responseBody Json?
  lockedAt     DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  expiresAt    DateTime

  @@unique([tenantId, key])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

model OutboxEvent {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String?   @db.Uuid
  type        String // domain event name
  payload     Json
  status      String    @default("pending") // pending | processing | done | failed
  attempts    Int       @default(0)
  lastError   String?
  availableAt DateTime  @default(now())
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([status, availableAt])
  @@map("outbox_events")
}

// ── Digital-banking: customer deposit accounts + internal transfers ──────────
// A customer-facing savings/current account holding a real balance, with its own
// transaction ledger (statement). Internal transfers move value atomically
// between two DepositAccounts, writing a debit + credit leg linked by Transfer.

model DepositAccount {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  customerId    String    @db.Uuid
  accountNumber String    @unique
  type          String    @default("savings") // savings | current
  currency      String    @default("INR")
  balance       Decimal   @default(0) @db.Decimal(18, 4)
  status        String    @default("active") // active | dormant | frozen | closed
  openedAt      DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  customer     Customer             @relation(fields: [customerId], references: [id])
  transactions DepositTransaction[]
  transfersOut Transfer[]           @relation("TransferFrom")
  transfersIn  Transfer[]           @relation("TransferTo")

  @@index([tenantId])
  @@index([tenantId, customerId])
  @@index([tenantId, status])
  @@map("deposit_accounts")
}

model DepositTransaction {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @db.Uuid
  depositAccountId String   @db.Uuid
  date             DateTime @default(now())
  type             String // credit | debit
  amount           Decimal  @db.Decimal(18, 4) // always positive; `type` carries direction
  balanceAfter     Decimal  @db.Decimal(18, 4)
  description      String?
  reference        String?
  transferId       String?  @db.Uuid
  createdAt        DateTime @default(now())

  depositAccount DepositAccount @relation(fields: [depositAccountId], references: [id], onDelete: Cascade)
  transfer       Transfer?      @relation(fields: [transferId], references: [id])

  @@index([tenantId, depositAccountId])
  @@index([tenantId, date])
  @@map("deposit_transactions")
}

model Transfer {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  fromAccountId String   @db.Uuid
  toAccountId   String   @db.Uuid
  amount        Decimal  @db.Decimal(18, 4)
  currency      String   @default("INR")
  reference     String?
  description   String?
  status        String   @default("completed") // completed
  createdBy     String   @db.Uuid
  createdAt     DateTime @default(now())

  fromAccount  DepositAccount       @relation("TransferFrom", fields: [fromAccountId], references: [id])
  toAccount    DepositAccount       @relation("TransferTo", fields: [toAccountId], references: [id])
  transactions DepositTransaction[]

  @@index([tenantId])
  @@index([tenantId, fromAccountId])
  @@index([tenantId, toAccountId])
  @@map("transfers")
}
