# ─────────────────────────────────────────────────────────────
# FinPay backend configuration
# Copy to `.env` and adjust. Requires a PostgreSQL database.
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3030
API_VERSION=v1

# Database — PostgreSQL (required). The schema uses Prisma Migrate; an initial
# migration lives in prisma/migrations. Point this at a live Postgres instance.
DATABASE_URL="postgresql://finpay:finpay@localhost:5432/finpay?schema=public"

# Redis — OPTIONAL. When set, the cache + BullMQ queue use Redis; otherwise the
# app transparently falls back to in-memory adapters (fine for dev/single-node).
# REDIS_URL="redis://localhost:6379"

# Auth — access + refresh JWT secrets (use long random values in production).
JWT_ACCESS_SECRET=change-me-finpay-access-secret
JWT_REFRESH_SECRET=change-me-finpay-refresh-secret
JWT_ACCESS_TTL=900          # access token lifetime, seconds (15 min)
JWT_REFRESH_TTL=86400       # refresh / session lifetime, seconds (24 hours)
BCRYPT_ROUNDS=12

# CORS — comma-separated allowed origins (the Vite frontend, etc.)
CORS_ORIGINS="http://localhost:5173,http://localhost:4173,http://localhost:3000"

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=10

# File storage (local disk driver by default)
STORAGE_DRIVER=local
STORAGE_DIR=./storage

# Public frontend URL (used in password-reset email links)
APP_URL="http://localhost:5173"

# Transactional email — when SMTP_HOST is unset, messages are logged (dev sink).
# In production, configure SMTP so forgot-password emails are delivered.
MAIL_FROM="Valoris Fusion <noreply@valorisfusion.com>"
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
